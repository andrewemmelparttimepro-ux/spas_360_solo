# ─── Supabase (client) ───────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_CLARITY_PROJECT_ID=

# ─── AI Sales Assistant (server / Vercel function) ───────────
# Provider: gemini (default) | glm | meta | anthropic | openai
AI_PROVIDER=gemini

# Gemini (default provider, currently keyed)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

# GLM 5.2 via Z.AI — set AI_PROVIDER=glm to use
GLM_API_KEY=
GLM_MODEL=glm-5.2
GLM_BASE_URL=https://api.z.ai/api/paas/v4

# Muse Spark 1.1 via Meta Model API — set AI_PROVIDER=meta to use
# MODEL_API_KEY is Meta's official server-side environment variable. Never use VITE_*.
MODEL_API_KEY=
META_MODEL=muse-spark-1.1
META_BASE_URL=https://api.meta.ai/v1

# Server-to-server key for the Magic City website's customer-facing Ari path.
# Never expose this through VITE_* or browser code.
ARI_FORWARD_SECRET=

# Realtime transcription + Ari speech (server only). Clients never receive the API key.
ELEVENLABS_API_KEY=
# Optional ElevenLabs voice override. Defaults to the Adam premade voice.
ELEVENLABS_VOICE_ID=

# Anthropic Claude — set AI_PROVIDER=anthropic to use
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6   # use claude-opus-4-8 for premium demos

# OpenAI (optional fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Business texting (Twilio) — server / Vercel function ────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM=+17019299194
# Inbound webhook writes need the service-role key (Supabase dashboard → Settings → API)
SUPABASE_SERVICE_ROLE_KEY=
# Optional: override if the webhook URL ever differs from the default prod URL
TWILIO_WEBHOOK_URL=https://spas360solo.vercel.app/api/sms-inbound
