# ─── Supabase (client) ───────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── AI Sales Assistant (server / Vercel function) ───────────
# Provider: gemini (default) | anthropic | openai
AI_PROVIDER=gemini

# Gemini (default provider, currently keyed)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

# Anthropic Claude — set AI_PROVIDER=anthropic to use
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6   # use claude-opus-4-8 for premium demos

# OpenAI (optional fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
